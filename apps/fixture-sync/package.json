{
  "name": "@wac/fixture-sync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "fixture-sync": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node22 --external:playwright --external:playwright-core --outfile=dist/index.js --banner:js=\"import{createRequire as __cr}from'module';const require=__cr(import.meta.url);\"",
    "sync": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "@supabase/supabase-js": "^2.46.2",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@wac/shared": "workspace:*",
    "esbuild": "^0.28.0",
    "typescript": "^5.6.3"
  }
}
