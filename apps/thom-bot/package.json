{
  "name": "@wac/thom-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:widget": "vite --config widget/vite.config.ts",
    "build:widget": "vite build --config widget/vite.config.ts",
    "deploy": "pnpm build:widget && wrangler deploy",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p widget/tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.46.2",
    "@wac/shared": "workspace:*",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "wrangler": "^4.0.0"
  }
}
