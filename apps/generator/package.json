{
  "name": "@wac/generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/server.js --external:sharp --banner:js=\"import{createRequire as __cr}from'module';const require=__cr(import.meta.url);\"",
    "start": "node dist/server.js",
    "dev": "esbuild src/server.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/server.js --external:sharp --banner:js=\"import{createRequire as __cr}from'module';const require=__cr(import.meta.url);\" --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@supabase/supabase-js": "^2.46.2",
    "@types/node": "^22.10.2",
    "@wac/shared": "workspace:*",
    "esbuild": "^0.28.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
