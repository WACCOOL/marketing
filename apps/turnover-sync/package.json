{
  "name": "@wac/turnover-sync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "turnover-sync": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node22 --external:cpu-features \"--external:./crypto/build/Release/sshcrypto.node\" --outfile=dist/index.js --banner:js=\"import{createRequire as __cr}from'module';const require=__cr(import.meta.url);import{fileURLToPath as __futp}from'url';import{dirname as __pdn}from'path';const __filename=__futp(import.meta.url);const __dirname=__pdn(__filename);\"",
    "sync": "node --env-file-if-exists=.env dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@supabase/supabase-js": "^2.46.2",
    "ssh2-sftp-client": "^12.0.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ssh2-sftp-client": "^9.0.4",
    "@wac/shared": "workspace:*",
    "esbuild": "^0.28.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
