# Same variable names as the Node apps and GitHub Actions secrets.
# Copy to .env (gitignored). If .env is absent, config.py falls back to
# reading apps/api/.dev.vars locally.
HUBSPOT_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=wac-marketing-assets
# Optional overrides
# WAC_FORECAST_DATA_DIR=/path/off/onedrive/data
# FORECAST_WRITE=0
