SUPABASE_URL=https://stmphhslrjhtzmvqilqu.supabase.co
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
HUBSPOT_TOKEN=
# Sales Layer PIM (Phase 2) — legacy Connector API (api.saleslayer.com).
# Both values come from the Connector in the Sales Layer PIM (must be published).
SALES_LAYER_CONNECTOR_ID=
SALES_LAYER_SECRET_KEY=
# Optional overrides:
# SALES_LAYER_API_HOST=api.saleslayer.com
# SALES_LAYER_API_VERSION=1.18
# SALES_LAYER_DIMENSION_UNIT=in
# Pin the exact product field that holds the brand if auto-discovery picks wrong
# (the sync logs which field it used and how many products got a brand).
# SALES_LAYER_BRAND_FIELD=
# Phase 2b — R2 S3-API creds forwarded into the generation Container so it can
# write generated assets. Create an R2 API token (Object Read & Write) in the
# Cloudflare dashboard. Endpoint is https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=wac-marketing-assets
# Phase 2d — AI image providers for the Application Image hybrid/concept modes.
# Forwarded into the generation Container. Leave blank to run composite-only.
#   BFL_API_KEY    — Black Forest Labs (FLUX.1 Fill masked inpainting), bfl.ai
#   GEMINI_API_KEY — Google Gemini (harmonization + concept + scene generation +
#                    segmentation-based background removal of fixture cutouts)
BFL_API_KEY=
GEMINI_API_KEY=
# Gemini model for text-to-room scene generation. Defaults to a Gemini 3 image
# model (4K-capable) in the container; override to pin a specific model.
# GEMINI_SCENE_MODEL=gemini-3-pro-image
# Gemini model for background removal (segmentation). Defaults to gemini-2.5-flash.
# GEMINI_SEGMENT_MODEL=gemini-2.5-flash
